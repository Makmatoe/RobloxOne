<Window x:Class="RobloxOneLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Roblox One" Width="1180" Height="820" MinWidth="860" MinHeight="520"
        WindowStartupLocation="CenterScreen" Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="292"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Account library and local tools stay separate from the launch workspace. -->
        <Border Grid.Column="0" Background="#0E1118"
                BorderBrush="#202634" BorderThickness="0,0,1,0">
            <Grid Margin="24,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="44" Height="44" CornerRadius="14"
                            Background="{StaticResource AccentBrush}">
                        <TextBlock Text="R1" Foreground="White" FontSize="16"
                                   FontWeight="Bold" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,1,0,0">
                        <TextBlock Text="ROBLOX ONE" Foreground="White"
                                   FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="Local launch workspace"
                                   Foreground="{StaticResource MutedBrush}" FontSize="12"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Margin="0,28,0,22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="ACCOUNT LIBRARY" Foreground="#68748A"
                                   FontSize="11" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="LOCAL" HorizontalAlignment="Right"
                                   Foreground="#536077" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" Margin="0,12,0,8"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="AccountsList"/>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2">
                        <Button x:Name="AddAccountButton"
                                Click="AddAccountButton_Click" Background="#191E2A"
                                Foreground="#A99BFF" Padding="12,10"
                                HorizontalContentAlignment="Left"
                                AutomationProperties.Name="Add account"
                                ToolTip="Create another isolated local Roblox session">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource ButtonIcon}"
                                      Data="{StaticResource IconAdd}" Margin="0,0,9,0"/>
                                <TextBlock Text="Add account" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Grid Margin="0,5,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="EditAccountButton"
                                    Click="EditAccountButton_Click" Background="Transparent"
                                    Foreground="#8E99AD" Padding="8,9" Margin="0,0,3,0"
                                    AutomationProperties.Name="Edit selected account"
                                    ToolTip="Customize the selected account label and color">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconEdit}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Edit" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SoundSettingsButton" Grid.Column="1"
                                    Click="SoundSettingsButton_Click" Background="Transparent"
                                    Foreground="#8E99AD" Padding="8,9" Margin="3,0,0,0"
                                    AutomationProperties.Name="Sound settings"
                                    ToolTip="Choose interface and startup sounds">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconSound}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Sounds" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="CLIENT TOOLS" Foreground="#68748A"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Button x:Name="CloseAllInstancesButton"
                            Click="CloseAllInstancesButton_Click"
                            Background="#21171D" Foreground="#ED93A4" Padding="12,10"
                            HorizontalContentAlignment="Left"
                            AutomationProperties.Name="Close all Roblox instances"
                            ToolTip="Close every verified RobloxPlayerBeta process, including background instances">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Data="{StaticResource IconCloseAll}" Margin="0,0,9,0"/>
                            <TextBlock Text="Close all" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ResetButton"
                            Click="ResetButton_Click" Background="Transparent"
                            Foreground="#727E93" Padding="4,9" Margin="0,5,0,0"
                            HorizontalContentAlignment="Left"
                            AutomationProperties.Name="Remove selected account"
                            ToolTip="Clear and remove the selected local account profile">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Data="{StaticResource IconTrash}" Margin="0,0,9,0"/>
                            <TextBlock Text="Remove" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Border Height="1" Background="#202634" Margin="0,10,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="{StaticResource IconLock}" Width="13" Height="13"
                              Stroke="#566176" HorizontalAlignment="Left"
                              VerticalAlignment="Top" Margin="1,1,0,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="Accounts, history, and sessions stay on this PC."
                                   Foreground="#566176" FontSize="11"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
            <Grid Margin="24,24,24,12" MinWidth="500" MinHeight="520">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="LAUNCH CENTER"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="Choose where to play."
                                   Foreground="White" FontSize="34"
                                   FontWeight="SemiBold" Margin="0,7,0,0"/>
                        <TextBlock Text="Your account sessions and launch history remain local."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="14" Margin="0,7,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button x:Name="InstallUpdateButton"
                                Style="{StaticResource IconOnlyButton}"
                                Width="34" Height="34" Padding="8"
                                Margin="0,0,8,0"
                                Background="#151A24" Foreground="#8E99AD"
                                Click="InstallUpdateButton_Click"
                                AutomationProperties.Name="Check for signed updates"
                                ToolTip="Check GitHub for a signed Roblox One update">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Data="{StaticResource IconUpdate}"/>
                        </Button>
                        <Border Background="#151A24" CornerRadius="10"
                                BorderBrush="#252D3B" BorderThickness="1"
                                Padding="12,7">
                            <TextBlock Text="LOCAL ONLY" Foreground="#718097"
                                       FontSize="9" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Launch and Recent are destination workspaces only. -->
                <Grid Grid.Row="1" Margin="0,26,0,0" MinHeight="400">
                    <Border x:Name="LauncherPanel"
                            Background="{StaticResource PanelBrush}" CornerRadius="22"
                            BorderBrush="#242B3A" BorderThickness="1" Padding="28"
                            MinHeight="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,22">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="LaunchTabButton"
                                            Click="LaunchTabButton_Click"
                                            Background="#2A3142" Padding="14,8"
                                            Margin="0,0,8,0"
                                            AutomationProperties.Name="Launch"
                                            AutomationProperties.ItemStatus="Selected"
                                            ToolTip="Open the launch destination workspace">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource ButtonIcon}"
                                                  Data="{StaticResource IconLaunch}"
                                                  Width="15" Height="15" Margin="0,0,8,0"/>
                                            <TextBlock Text="Launch" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="RecentTabButton"
                                            Click="RecentTabButton_Click"
                                            Background="Transparent" Foreground="#98A3B8"
                                            Padding="12,8"
                                            AutomationProperties.Name="Recent"
                                            AutomationProperties.ItemStatus="Not selected"
                                            ToolTip="Show recently launched experiences">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource ButtonIcon}"
                                                  Data="{StaticResource IconHistory}"
                                                  Width="16" Height="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="Recent" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="One destination per account"
                                           Foreground="#657086" FontSize="10"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Grid x:Name="LaunchTabPanel" Grid.Row="1" MinHeight="310">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Destination" Foreground="White"
                                               FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Paste a Place ID, official experience URL, private-server link, code= value, or a tracked Server JobId."
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="13" Margin="0,5,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,18,0,0">
                                    <Border Height="50"
                                            Style="{StaticResource TextFieldShell}">
                                        <TextBox x:Name="PlaceIdBox"
                                                 Style="{StaticResource EmbeddedTextBox}"
                                                 TextWrapping="NoWrap"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                 TextChanged="PlaceIdBox_TextChanged"
                                                 KeyDown="PlaceIdBox_KeyDown"
                                                 ToolTip="Place ID, official Roblox game URL, private-server URL, share code, or Server JobId saved from Recent"
                                                 AutomationProperties.Name="Roblox destination"/>
                                    </Border>
                                    <TextBlock x:Name="DestinationValidationText"
                                               Visibility="Collapsed"
                                               Foreground="#ED93A4" FontSize="11"
                                               Margin="4,7,4,0" TextWrapping="Wrap"
                                               AutomationProperties.LiveSetting="Polite"/>
                                </StackPanel>

                                <Border Grid.Row="2" Margin="0,20,0,20"
                                        Background="#0D1017" CornerRadius="14"
                                        BorderBrush="#202737" BorderThickness="1"
                                        Padding="18" VerticalAlignment="Stretch">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="10"
                                                Background="#211D39"
                                                VerticalAlignment="Center">
                                            <Path Style="{StaticResource ButtonIcon}"
                                                  Data="{StaticResource IconAccount}"
                                                  Stroke="#A99BFF" Width="17" Height="17"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="The selected account controls this launch"
                                                       Foreground="#D7DDEA" FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Its destination is remembered separately; Recent remains shared across accounts."
                                                       Foreground="#778399" FontSize="11"
                                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="SignInButton"
                                            Click="SignInButton_Click" Background="#252C3B"
                                            Visibility="Collapsed" Margin="0,0,12,0"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.Name="Sign in to Roblox"
                                            ToolTip="Open the official Roblox sign-in page for this account">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource ButtonIcon}"
                                                  Data="{StaticResource IconBrowser}" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="SignInButtonLabel" Text="Sign in"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="BatchLaunchButton"
                                                Click="BatchLaunchButton_Click" MinWidth="145"
                                                IsEnabled="False" Margin="0,0,10,0"
                                                Background="#252C3B"
                                                AutomationProperties.Name="Batch launch"
                                                ToolTip="Launch this destination sequentially with multiple accounts">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource ButtonIcon}"
                                                      Data="{StaticResource IconBatch}" Margin="0,0,8,0"/>
                                                <TextBlock Text="Batch" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="LaunchButton"
                                                Click="LaunchButton_Click" MinWidth="210"
                                                IsEnabled="False"
                                                AutomationProperties.Name="Launch Roblox"
                                                ToolTip="Launch immediately with the selected account">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource ButtonIcon}"
                                                      Data="{StaticResource IconLaunch}" Margin="0,0,9,0"/>
                                                <TextBlock x:Name="LaunchButtonLabel" Text="Launch"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <Grid x:Name="RecentTabPanel" Grid.Row="1"
                                  Visibility="Collapsed" MinHeight="310">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Recent experiences" Foreground="White"
                                               FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="Select an item to reuse its saved destination with the active account."
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="13" Margin="0,5,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Grid Grid.Row="1" Margin="0,15,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="AllTypeFilterButton" Content="All"
                                                Click="AllTypeFilterButton_Click"
                                                Padding="11,7" Background="#2A3142"
                                                Margin="0,0,6,0"
                                                AutomationProperties.ItemStatus="Selected"/>
                                        <Button x:Name="PublicFilterButton" Content="Public"
                                                Click="PublicFilterButton_Click"
                                                Padding="11,7" Background="Transparent"
                                                Foreground="#98A3B8" Margin="0,0,6,0"
                                                AutomationProperties.ItemStatus="Not selected"/>
                                        <Button x:Name="PrivateFilterButton" Content="Private"
                                                Click="PrivateFilterButton_Click"
                                                Padding="11,7" Background="Transparent"
                                                Foreground="#98A3B8"
                                                AutomationProperties.ItemStatus="Not selected"/>
                                    </StackPanel>
                                    <ComboBox x:Name="AccountFilterCombo" Grid.Column="2"
                                              Width="190" Height="36"
                                              SelectionChanged="AccountFilterCombo_SelectionChanged"
                                              Background="#252C3B" Foreground="White"
                                              BorderBrush="#343D50" Padding="8,4"
                                              AutomationProperties.Name="Recent account filter"/>
                                </Grid>
                                <ScrollViewer Grid.Row="2" Margin="0,14,0,14"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="RecentExperiencesList"/>
                                </ScrollViewer>
                                <Grid Grid.Row="3">
                                    <TextBlock x:Name="RecentPrivacyText"
                                               Text="History is shared across accounts and stored only on this PC."
                                               Foreground="#68748A" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="ClearHistoryButton"
                                            Style="{StaticResource IconOnlyButton}"
                                            HorizontalAlignment="Right"
                                            Click="ClearHistoryButton_Click"
                                            Background="Transparent" Foreground="#8B96AA"
                                            AutomationProperties.Name="Clear history"
                                            ToolTip="Remove non-favorite history in the selected type">
                                        <Path Style="{StaticResource ButtonIcon}"
                                              Data="{StaticResource IconTrash}"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="BrowserPanel" Visibility="Collapsed"
                            Background="{StaticResource PanelBrush}" CornerRadius="22"
                            BorderBrush="#242B3A" BorderThickness="1"
                            ClipToBounds="True" MinHeight="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="68"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Background="#171B25">
                                <StackPanel Orientation="Horizontal" Margin="20,0,118,0"
                                            VerticalAlignment="Center">
                                    <Border Width="9" Height="9" CornerRadius="5"
                                            Background="#7C5CFC" Margin="0,0,10,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Official Roblox sign-in"
                                                   Foreground="White" FontSize="14"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Extensions are unavailable here; right-click Paste or press Ctrl+V."
                                                   Foreground="#7F8BA0" FontSize="10"
                                                   Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button HorizontalAlignment="Right"
                                        Margin="0,10,12,10" Padding="18,7"
                                        Background="#293041"
                                        AutomationProperties.Name="Back to launcher"
                                        ToolTip="Back to the launch workspace"
                                        Click="BrowserBackButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource ButtonIcon}"
                                              Data="{StaticResource IconBack}" Margin="0,0,8,0"/>
                                        <TextBlock Text="Back" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Grid x:Name="BrowserHost" Grid.Row="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            </ScrollViewer>

                <!-- General status is independent from the destination workspace. -->
                <Border Grid.Row="1" Margin="24,8,24,0" Padding="16"
                        Background="#10141D" CornerRadius="18"
                        BorderBrush="#242B3A" BorderThickness="1" MinHeight="102">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="StatusIconBorder" Width="50" Height="50"
                                MinWidth="50" MinHeight="50" CornerRadius="15"
                                Background="#1C2230" VerticalAlignment="Center">
                            <Path x:Name="StatusIconGlyph" Width="23" Height="23"
                                  Margin="13" Data="{StaticResource IconActivity}"
                                  Stroke="{StaticResource AccentBrush}"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Stretch="Uniform"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="16,0,18,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="CURRENT ACTIVITY" Foreground="#657086"
                                       FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="StatusTitle"
                                       Text="Checking your Roblox session…"
                                       Foreground="White" FontSize="15"
                                       FontWeight="SemiBold" Margin="0,5,0,0"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="StatusDetail"
                                       Text="This normally takes only a moment."
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Border x:Name="SessionBadgeBorder"
                                    Background="#17251F" CornerRadius="9" Padding="11,6"
                                    HorizontalAlignment="Right">
                                <TextBlock x:Name="SessionBadge" Text="CHECKING SESSION"
                                           Foreground="#57D9A3" FontSize="10"
                                           FontWeight="Bold"/>
                            </Border>
                            <Button x:Name="CancelBatchButton"
                                    Visibility="Collapsed" IsEnabled="False"
                                    Click="CancelBatchButton_Click"
                                    Content="Cancel batch" Margin="0,7,0,0"
                                    Padding="10,6" FontSize="11"
                                    HorizontalAlignment="Right"
                                    Background="#2A171D" Foreground="#ED93A4"
                                    AutomationProperties.Name="Cancel batch launch"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="24,12,24,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Roblox Player and Microsoft Edge WebView2 are required."
                               Foreground="#586378" FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="1"
                               Text="Not affiliated with Roblox Corporation."
                               Foreground="#4D586C" FontSize="11"
                               Margin="16,0,0,0"
                               HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
    </Grid>
</Window>
