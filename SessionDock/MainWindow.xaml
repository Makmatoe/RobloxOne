<Window x:Class="SessionDock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SessionDock" Width="1080" Height="720"
        MinWidth="800" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SubtleBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="RailIconButton" TargetType="Button"
               BasedOn="{StaticResource IconOnlyButton}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="#191D23"/>
            <Setter Property="Foreground" Value="#BEC6D2"/>
        </Style>

        <Style x:Key="QuietButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#20252D"/>
            <Setter Property="Foreground" Value="#D6DCE5"/>
        </Style>

        <Style x:Key="SegmentButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Slim utility rail. Account management lives in the strip above the workspace. -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="#272C34"
                BorderThickness="0,0,1,0">
            <Grid Margin="12,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Width="40" Height="40" CornerRadius="10"
                        Background="{StaticResource AccentBrush}"
                        ToolTip="SessionDock — local Roblox launcher">
                    <TextBlock Text="SD" Foreground="White" FontSize="13"
                               FontWeight="Bold" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Row="2">
                    <Button x:Name="SoundSettingsButton"
                            Style="{StaticResource RailIconButton}"
                            Click="SoundSettingsButton_Click"
                            Margin="0,0,0,6"
                            AutomationProperties.Name="Sound settings"
                            ToolTip="Sound settings">
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="{StaticResource IconSound}"/>
                    </Button>
                    <Button x:Name="IntegrationsButton"
                            Style="{StaticResource RailIconButton}"
                            Click="IntegrationsButton_Click"
                            Margin="0,0,0,6"
                            AutomationProperties.Name="Manage integrations"
                            ToolTip="Manage integrations">
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="{StaticResource IconIntegration}"/>
                    </Button>
                    <Button x:Name="RunningClientsButton"
                            Style="{StaticResource RailIconButton}"
                            Click="RunningClientsButton_Click"
                            Margin="0,0,0,10"
                            AutomationProperties.Name="Manage running Roblox clients"
                            AutomationProperties.HelpText="View and close individual verified Roblox Player processes"
                            ToolTip="View and close running Roblox clients">
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="{StaticResource IconClients}"/>
                    </Button>
                    <Border Height="1" Background="#303640" Margin="4,0,4,10"/>
                    <Border Width="40" Height="32" CornerRadius="8"
                            Background="#15181D"
                            ToolTip="Accounts, history, and sessions stay on this PC">
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="{StaticResource IconLock}"
                              Width="14" Height="14" Stroke="#8A94A3"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main launch workspace. -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="20,10,20,7">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Choose where to play"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Select an account, enter a destination, and launch."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="ReleaseNotesButton"
                            Style="{StaticResource IconOnlyButton}"
                            Width="34" Height="34" Padding="8"
                            Margin="0,0,6,0"
                            Background="#1B1F26" Foreground="#AEB7C5"
                            Click="ReleaseNotesButton_Click"
                            AutomationProperties.Name="View current and previous release notes"
                            AutomationProperties.HelpText="Shows changes in the installed release and the release before it"
                            ToolTip="View included SessionDock release notes">
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="{StaticResource IconReleaseNotes}"/>
                    </Button>
                    <Button x:Name="InstallUpdateButton"
                            Style="{StaticResource IconOnlyButton}"
                            Width="34" Height="34" Padding="8"
                            Margin="0,0,8,0"
                            Background="#1B1F26" Foreground="#AEB7C5"
                            Click="InstallUpdateButton_Click"
                            AutomationProperties.Name="Check for signed updates"
                            ToolTip="Check GitHub for a signed SessionDock update">
                        <Path Style="{StaticResource ButtonIcon}"
                              Data="{StaticResource IconUpdate}"/>
                    </Button>
                    <Border Background="#171A20" CornerRadius="8"
                            BorderBrush="#2B313B" BorderThickness="1"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="6" Height="6" CornerRadius="3"
                                    Background="#63D39C" Margin="0,0,7,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="LOCAL" Foreground="#8F99A8"
                                       FontSize="9" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- The account selector remains visible in both Launch and Recent. -->
            <Border Grid.Row="1" Padding="20,5"
                    Background="#101318" BorderBrush="#292F38"
                    BorderThickness="0,1,0,1" MinHeight="64">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Width="58" VerticalAlignment="Center">
                        <TextBlock Text="ACCOUNT" Style="{StaticResource SectionLabel}"/>
                        <TextBlock Text="Local slot" Foreground="{StaticResource SubtleBrush}"
                                   FontSize="9" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ScrollViewer x:Name="AccountsScrollViewer" Grid.Column="1"
                                  Margin="8,0,12,0"
                                  VerticalAlignment="Center"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  PanningMode="HorizontalOnly"
                                  PreviewMouseWheel="AccountsScrollViewer_PreviewMouseWheel"
                                  AutomationProperties.Name="Saved accounts">
                        <StackPanel x:Name="AccountsList" Orientation="Horizontal"/>
                    </ScrollViewer>
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="AddAccountButton"
                                Style="{StaticResource IconOnlyButton}"
                                Width="34" Height="34" Padding="8"
                                Background="#20252D" Foreground="#C9D9FA"
                                Click="AddAccountButton_Click"
                                AutomationProperties.Name="Add account"
                                ToolTip="Add another isolated Roblox account">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Data="{StaticResource IconAdd}"/>
                        </Button>
                        <Button x:Name="EditAccountButton"
                                Style="{StaticResource IconOnlyButton}"
                                Width="34" Height="34" Padding="8"
                                Margin="6,0,0,0"
                                Background="#20252D" Foreground="#C9D1DC"
                                Click="EditAccountButton_Click"
                                AutomationProperties.Name="Edit selected account"
                                ToolTip="Change the selected account label and color">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Data="{StaticResource IconEdit}"/>
                        </Button>
                        <Button x:Name="ResetButton"
                                Style="{StaticResource IconOnlyButton}"
                                Width="34" Height="34" Padding="8"
                                Margin="6,0,0,0"
                                Background="#27181C" Foreground="#F0A0AD"
                                Click="ResetButton_Click"
                                AutomationProperties.Name="Remove selected account"
                                ToolTip="Clear and remove the selected local account profile">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Data="{StaticResource IconTrash}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="20,10,20,8">
                <Border x:Name="LauncherPanel"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1" CornerRadius="12"
                        Padding="18,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="LaunchTabButton"
                                        Style="{StaticResource SegmentButton}"
                                        Click="LaunchTabButton_Click"
                                        Background="#252A33" Foreground="White"
                                        Margin="0,0,6,0"
                                        AutomationProperties.Name="Launch"
                                        AutomationProperties.ItemStatus="Selected"
                                        ToolTip="Open the launch destination workspace">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource ButtonIcon}"
                                              Data="{StaticResource IconLaunch}"
                                              Width="14" Height="14" Margin="0,0,7,0"/>
                                        <TextBlock Text="Launch"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="RecentTabButton"
                                        Style="{StaticResource SegmentButton}"
                                        Click="RecentTabButton_Click"
                                        AutomationProperties.Name="Recent"
                                        AutomationProperties.ItemStatus="Not selected"
                                        ToolTip="Show recently launched experiences">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Style="{StaticResource ButtonIcon}"
                                              Data="{StaticResource IconHistory}"
                                              Width="14" Height="14" Margin="0,0,7,0"/>
                                        <TextBlock Text="Recent"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="Destination saved per account"
                                       Foreground="{StaticResource SubtleBrush}"
                                       FontSize="10" VerticalAlignment="Center"/>
                        </Grid>

                        <ScrollViewer x:Name="LaunchTabPanel" Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly">
                            <Grid Margin="0,14,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Destination"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="Place ID, Roblox URL, private-server link, share code, or tracked Job ID."
                                               Foreground="{StaticResource MutedBrush}"
                                               FontSize="12" Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,14,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Height="46"
                                                Style="{StaticResource TextFieldShell}">
                                            <TextBox x:Name="PlaceIdBox"
                                                     Style="{StaticResource EmbeddedTextBox}"
                                                     TextWrapping="NoWrap"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                     TextChanged="PlaceIdBox_TextChanged"
                                                     LostKeyboardFocus="PlaceIdBox_LostKeyboardFocus"
                                                     KeyDown="PlaceIdBox_KeyDown"
                                                     ToolTip="Place ID, official Roblox URL, private-server link, share code, or tracked Server JobId"
                                                     AutomationProperties.Name="Roblox destination"/>
                                        </Border>
                                        <Button x:Name="SetDestinationForAllButton"
                                                Grid.Column="1" Height="46" MinWidth="116"
                                                Margin="8,0,0,0" Padding="13,9"
                                                Style="{StaticResource QuietButton}"
                                                IsEnabled="False"
                                                Click="SetDestinationForAllButton_Click"
                                                ToolTip="Copy this valid destination to every saved account"
                                                AutomationProperties.Name="Set destination for all accounts">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource ButtonIcon}"
                                                      Data="{StaticResource IconBatch}"
                                                      Width="14" Height="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Set for all"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <TextBlock x:Name="DestinationValidationText"
                                               Visibility="Collapsed"
                                               Foreground="#F08A9B" FontSize="11"
                                               Margin="3,7,3,0" TextWrapping="Wrap"
                                               AutomationProperties.LiveSetting="Polite"/>
                                    <Border x:Name="ServerJobIdWarningPanel"
                                            Visibility="Collapsed"
                                            Margin="0,8,0,0" Padding="11,9"
                                            Background="#241D10" BorderBrush="#5B481D"
                                            BorderThickness="1" CornerRadius="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="21"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Data="{StaticResource IconWarning}"
                                                  Width="15" Height="15"
                                                  Stretch="Uniform" Fill="Transparent"
                                                  Stroke="#EBC56B" StrokeThickness="1.8"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  VerticalAlignment="Top"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Tracked Job ID: Roblox may close the Player if this server is no longer available."
                                                       Foreground="#DFC477" FontSize="11"
                                                       TextWrapping="Wrap"
                                                       AutomationProperties.LiveSetting="Polite"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Row="2" Margin="0,16,0,16"
                                        Background="#13161B" CornerRadius="8"
                                        BorderBrush="#262C35" BorderThickness="1"
                                        Padding="13,11">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="26" Height="26" CornerRadius="7"
                                                Background="{StaticResource AccentSurfaceBrush}"
                                                VerticalAlignment="Center">
                                            <Path Style="{StaticResource ButtonIcon}"
                                                  Data="{StaticResource IconAccount}"
                                                  Stroke="#8FB8FF" Width="14" Height="14"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="9,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Launching with the selected account"
                                                       Foreground="#E2E6ED" FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="Each account remembers its own destination; history remains shared."
                                                       Foreground="{StaticResource SubtleBrush}"
                                                       FontSize="10" Margin="0,2,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="SignInButton"
                                            Style="{StaticResource QuietButton}"
                                            Click="SignInButton_Click"
                                            Visibility="Collapsed"
                                            HorizontalAlignment="Left"
                                            AutomationProperties.Name="Sign in to Roblox"
                                            ToolTip="Open the official Roblox sign-in page for this account">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource ButtonIcon}"
                                                  Data="{StaticResource IconBrowser}"
                                                  Width="15" Height="15" Margin="0,0,7,0"/>
                                            <TextBlock x:Name="SignInButtonLabel" Text="Sign in"/>
                                        </StackPanel>
                                    </Button>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="BatchLaunchButton"
                                                Style="{StaticResource QuietButton}"
                                                Click="BatchLaunchButton_Click"
                                                MinWidth="118" IsEnabled="False"
                                                Margin="0,0,8,0"
                                                AutomationProperties.Name="Batch launch"
                                                ToolTip="Launch each selected account's saved destination">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource ButtonIcon}"
                                                      Data="{StaticResource IconBatch}"
                                                      Width="15" Height="15" Margin="0,0,7,0"/>
                                                <TextBlock Text="Batch"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="LaunchButton"
                                                Click="LaunchButton_Click"
                                                MinWidth="170" IsEnabled="False"
                                                AutomationProperties.Name="Launch Roblox"
                                                ToolTip="Launch immediately with the selected account">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Style="{StaticResource ButtonIcon}"
                                                      Data="{StaticResource IconLaunch}"
                                                      Width="15" Height="15" Margin="0,0,7,0"/>
                                                <TextBlock x:Name="LaunchButtonLabel" Text="Launch"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </ScrollViewer>

                        <Grid x:Name="RecentTabPanel" Grid.Row="1"
                              Visibility="Collapsed" Margin="0,14,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Recent experiences"
                                           Foreground="{StaticResource TextBrush}"
                                           FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="Reuse a destination with the currently selected account."
                                           Foreground="{StaticResource MutedBrush}"
                                           FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="AllTypeFilterButton" Content="All"
                                            Style="{StaticResource SegmentButton}"
                                            Click="AllTypeFilterButton_Click"
                                            Background="#252A33" Foreground="White"
                                            Padding="10,7" Margin="0,0,4,0"
                                            AutomationProperties.ItemStatus="Selected"/>
                                    <Button x:Name="PublicFilterButton" Content="Public"
                                            Style="{StaticResource SegmentButton}"
                                            Click="PublicFilterButton_Click"
                                            Padding="10,7" Margin="0,0,4,0"
                                            AutomationProperties.ItemStatus="Not selected"/>
                                    <Button x:Name="PrivateFilterButton" Content="Private"
                                            Style="{StaticResource SegmentButton}"
                                            Click="PrivateFilterButton_Click"
                                            Padding="10,7"
                                            AutomationProperties.ItemStatus="Not selected"/>
                                </StackPanel>
                                <ComboBox x:Name="AccountFilterCombo" Grid.Column="2"
                                          Width="168" Height="34"
                                          SelectionChanged="AccountFilterCombo_SelectionChanged"
                                          Padding="8,4"
                                          AutomationProperties.Name="Recent account filter"/>
                                <Button x:Name="ClearHistoryButton" Grid.Column="3"
                                        Style="{StaticResource IconOnlyButton}"
                                        Width="32" Height="32" Padding="7"
                                        Margin="8,0,0,0"
                                        Click="ClearHistoryButton_Click"
                                        Background="Transparent" Foreground="#9AA4B3"
                                        AutomationProperties.Name="Clear history"
                                        ToolTip="Remove non-favorite history in the selected type">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconTrash}"/>
                                </Button>
                            </Grid>
                            <ScrollViewer x:Name="RecentExperiencesScrollViewer"
                                          Grid.Row="2" Margin="0,6,0,4"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PanningMode="VerticalOnly"
                                          AutomationProperties.Name="Recent experiences list">
                                <StackPanel x:Name="RecentExperiencesList"/>
                            </ScrollViewer>
                            <Grid Grid.Row="3">
                                <TextBlock x:Name="RecentPrivacyText"
                                           Text="Shared across accounts • stored only on this PC"
                                           Foreground="{StaticResource SubtleBrush}"
                                           FontSize="10" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="BrowserPanel" Visibility="Collapsed"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource StrokeBrush}"
                        BorderThickness="1" CornerRadius="12"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="54"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Background="#14171C">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="16,0,12,0"
                                        VerticalAlignment="Center">
                                <Border Width="7" Height="7" CornerRadius="4"
                                        Background="{StaticResource AccentBrush}"
                                        Margin="0,0,9,0"/>
                                <StackPanel>
                                    <TextBlock Text="Official Roblox sign-in"
                                               Foreground="{StaticResource TextBrush}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Use Ctrl+V or right-click to paste"
                                               Foreground="{StaticResource SubtleBrush}"
                                               FontSize="9" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource QuietButton}"
                                    Margin="0,9,10,9" Padding="13,7"
                                    AutomationProperties.Name="Back to launcher"
                                    ToolTip="Back to the launch workspace"
                                    Click="BrowserBackButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconBack}"
                                          Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="Back"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Grid x:Name="BrowserHost" Grid.Row="1"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Compact activity strip. -->
            <Border Grid.Row="3" Margin="20,0,20,0" Padding="12,7"
                    Background="#14171C" CornerRadius="10"
                    BorderBrush="#272D36" BorderThickness="1" MinHeight="56">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="StatusIconBorder" Width="30" Height="30"
                            CornerRadius="8" Background="#1B2738"
                            VerticalAlignment="Center">
                        <Path x:Name="StatusIconGlyph" Width="15" Height="15"
                              Data="{StaticResource IconActivity}"
                              Stroke="{StaticResource AccentBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round" Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,14,0"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="StatusTitle"
                                   Text="Checking your Roblox session…"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="13" FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="StatusDetail"
                                   Text="This normally takes only a moment."
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="10" Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Border x:Name="SessionBadgeBorder"
                                Background="#17251F" CornerRadius="7"
                                Padding="9,5" HorizontalAlignment="Right">
                            <TextBlock x:Name="SessionBadge" Text="CHECKING SESSION"
                                       Foreground="#63D39C" FontSize="9"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <Button x:Name="CancelBatchButton"
                                Visibility="Collapsed" IsEnabled="False"
                                Click="CancelBatchButton_Click"
                                Content="Cancel batch" Margin="0,5,0,0"
                                Padding="8,5" FontSize="10"
                                HorizontalAlignment="Right"
                                Background="#2A171D" Foreground="#ED93A4"
                                AutomationProperties.Name="Cancel batch launch"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="4" Margin="20,5,20,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Roblox Player and Microsoft Edge WebView2 are required."
                           Foreground="{StaticResource SubtleBrush}" FontSize="10"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Grid.Column="1"
                           Text="Not affiliated with Roblox Corporation."
