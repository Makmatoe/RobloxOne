<Window x:Class="SessionDock.RunningClientsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Running Roblox clients" Width="640" Height="560"
        MinWidth="500" MinHeight="400" MaxWidth="860" MaxHeight="820"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text"
        UseLayoutRounding="True" ShowInTaskbar="False">
    <Border Style="{StaticResource DialogShell}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Running Roblox clients"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="SemiBold"/>
                    <TextBlock Text="Only verified Roblox Player processes owned by your Windows session can be closed."
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="12" Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Background="{DynamicResource InfoSurfaceBrush}"
                        CornerRadius="7" Padding="9,5"
                        VerticalAlignment="Top" Margin="14,2,0,0">
                    <TextBlock x:Name="ClientCountText" Text="CHECKING"
                               Foreground="{DynamicResource InfoTextBrush}"
                               FontSize="9"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <Border x:Name="WarningBorder" Grid.Row="1"
                    Visibility="Collapsed" Margin="0,14,0,0"
                    Padding="11,9"
                    Background="{DynamicResource WarningSurfaceBrush}"
                    BorderBrush="{DynamicResource WarningBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Path Data="{StaticResource IconWarning}"
                          Width="15" Height="15" Stretch="Uniform"
                          Fill="Transparent"
                          Stroke="{DynamicResource WarningTextBrush}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          VerticalAlignment="Top"/>
                    <TextBlock x:Name="WarningText" Grid.Column="1"
                               Foreground="{DynamicResource WarningTextBrush}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite"/>
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="0,14,0,14"
                    Background="{DynamicResource InsetSurfaceBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1" CornerRadius="9" Padding="6">
                <Grid>
                    <ScrollViewer x:Name="ClientsScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly"
                                  AutomationProperties.Name="Running Roblox clients">
                        <StackPanel x:Name="ClientsList"/>
                    </ScrollViewer>
                    <TextBlock x:Name="EmptyStateText"
                               Text="Checking for running clients…"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="13" TextAlignment="Center"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" Margin="24"/>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Text="Looking for verified Roblox Player processes…"
                           Foreground="{DynamicResource SubtleBrush}"
                           FontSize="11" TextWrapping="Wrap"
                           VerticalAlignment="Center" Margin="0,0,14,0"
                           AutomationProperties.LiveSetting="Polite"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="RefreshButton"
                            Background="{DynamicResource ControlSurfaceBrush}"
                            Foreground="{DynamicResource ControlTextBrush}"
                            Padding="13,8" Margin="0,0,8,0"
                            Click="RefreshButton_Click"
                            AutomationProperties.Name="Refresh running Roblox clients">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Data="{StaticResource IconRefresh}"
                                  Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Refresh"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="CloseAllButton"
                            Background="{DynamicResource ErrorSurfaceBrush}"
                            Foreground="{DynamicResource ErrorTextBrush}"
                            Padding="13,8" Margin="0,0,8,0"
                            Click="CloseAllButton_Click"
                            AutomationProperties.Name="Close all verified Roblox clients">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource ButtonIcon}"
                                  Data="{StaticResource IconCloseAll}"
                                  Width="14" Height="14" Margin="0,0,6,0"/>
                            <TextBlock Text="Close all"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="DoneButton" Content="Done"
                            IsCancel="True"
                            Background="{DynamicResource ControlSurfaceBrush}"
                            Foreground="{DynamicResource ControlTextBrush}"
                            Padding="15,8"
                            AutomationProperties.Name="Close running clients dialog"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
