<Window x:Class="SessionDock.HandleScopeIntegrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HandleScope integration" Width="720" Height="680"
        MinWidth="480" MinHeight="460" MaxWidth="920" MaxHeight="840"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text" UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display" ShowInTaskbar="False">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Margin="16" Padding="26" CornerRadius="20"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="#293042" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="46" Height="46" CornerRadius="14"
                                Background="#2A2348" VerticalAlignment="Top">
                            <Path Data="{StaticResource IconIntegration}"
                                  Width="22" Height="22" Stretch="Uniform"
                                  Fill="Transparent" Stroke="#A99BFF"
                                  StrokeThickness="1.8" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="HandleScope integration" Foreground="White"
                                       FontSize="24" FontWeight="SemiBold"/>
                            <TextBlock Text="Connect SessionDock to a separately installed local HandleScope API."
                                       Foreground="{StaticResource MutedBrush}" FontSize="13"
                                       Margin="0,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,24,0,0" Padding="18"
                            Background="#0D1017" CornerRadius="14"
                            BorderBrush="#293042" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="42"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="StateIconShell" Width="34" Height="34"
                                    CornerRadius="10" Background="#222938"
                                    VerticalAlignment="Top" HorizontalAlignment="Left">
                                <Path x:Name="StateIcon" Data="{StaticResource IconActivity}"
                                      Width="17" Height="17" Stretch="Uniform"
                                      Fill="Transparent" Stroke="#8E99AD"
                                      StrokeThickness="1.8" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,16,0">
                                <TextBlock x:Name="StateTitleText" Text="Checking local setup..."
                                           Foreground="White" FontSize="16"
                                           FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="StateDescriptionText"
                                           Text="SessionDock is inspecting local files only."
                                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                                           Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Border Grid.Column="2" x:Name="StateBadge"
                                    Background="#222938" CornerRadius="8"
                                    Padding="9,5" VerticalAlignment="Top">
                                <TextBlock x:Name="StateBadgeText" Text="CHECKING"
                                           Foreground="#AAB4C6" FontSize="9"
                                           FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="RepairWarningPanel" Grid.Row="2"
                            Visibility="Collapsed" Margin="0,12,0,0" Padding="15"
                            Background="#241D13" BorderBrush="#5C4726"
                            BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconWarning}" Width="18" Height="18"
                                  Stretch="Uniform" Fill="Transparent" Stroke="#E0A33A"
                                  StrokeThickness="1.8" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Configuration needs attention"
                                           Foreground="#F1BE61" FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="RepairWarningText"
                                           Text="SessionDock preserved the existing configuration and will not use it. Repair replaces only the SessionDock opt-in with the fixed, minimal Roblox policy; it does not reinstall or stop HandleScope."
                                           Foreground="#C7A873" FontSize="11"
                                           Margin="0,4,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,22,0,0">
                        <TextBlock Text="SETUP AND CONTROLS" Foreground="#7F8BA0"
                                   FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="Install HandleScope from its official release page and verify its published checksum, then use these explicit controls. SessionDock checks the expected local path but cannot authenticate an unsigned executable's publisher. It never downloads, installs, elevates, or silently starts HandleScope."
                                   Foreground="{StaticResource MutedBrush}" FontSize="12"
                                   Margin="0,7,0,0" TextWrapping="Wrap"/>

                        <WrapPanel Margin="0,15,0,0">
                            <Button x:Name="GetHandleScopeButton"
                                    Click="GetHandleScopeButton_Click"
                                    Background="#252C3B" Foreground="#D8DDEA"
                                    Padding="14,10" Margin="0,0,8,8"
                                    AutomationProperties.Name="Get HandleScope from official releases">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconUpdate}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Get HandleScope"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RefreshButton" Click="RefreshButton_Click"
                                    Background="#252C3B" Foreground="#D8DDEA"
                                    Padding="14,10" Margin="0,0,8,8"
                                    AutomationProperties.Name="Refresh HandleScope status">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconRefresh}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Refresh"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="StartApiButton" Click="StartApiButton_Click"
                                    Padding="14,10" Margin="0,0,8,8"
                                    AutomationProperties.Name="Start HandleScope API">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconLaunch}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Start API"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="EnableButton" Click="EnableButton_Click"
                                    Padding="14,10" Margin="0,0,8,8"
                                    AutomationProperties.Name="Enable HandleScope integration">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconCheck}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Enable"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="DisableButton" Click="DisableButton_Click"
                                    Background="#252C3B" Foreground="#D8DDEA"
                                    Padding="14,10" Margin="0,0,8,8"
                                    AutomationProperties.Name="Disable HandleScope integration">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconLock}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Disable"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="TestConnectionButton"
                                    Click="TestConnectionButton_Click"
                                    Background="#252C3B" Foreground="#D8DDEA"
                                    Padding="14,10" Margin="0,0,8,8"
                                    AutomationProperties.Name="Test HandleScope connection">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconActivity}" Margin="0,0,7,0"/>
                                    <TextBlock Text="Test connection"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RepairButton" Click="RepairButton_Click"
                                    Visibility="Collapsed" Background="#6A4B18"
                                    Foreground="#FFE0A0" Padding="14,10"
                                    Margin="0,0,8,8"
                                    AutomationProperties.Name="Repair HandleScope integration configuration">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource ButtonIcon}"
                                          Data="{StaticResource IconWarning}" Margin="0,0,7,0"/>
                                    <TextBlock x:Name="RepairButtonLabel"
                                               Text="Repair and enable"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <TextBlock x:Name="ActionStatusText" MinHeight="18"
                                   Foreground="#9AA6BA" FontSize="11"
                                   Margin="0,3,0,0" TextWrapping="Wrap"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>

                    <Grid Grid.Row="4" Margin="0,23,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Testing contacts only the checked loopback health endpoint. It never closes a handle."
                                   Foreground="#667287" FontSize="10"
                                   Margin="0,0,18,0" VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <Button Grid.Column="1" Content="Close" Click="CloseButton_Click"
                                IsCancel="True" Background="#252C3B"
                                Padding="20,10"/>
                    </Grid>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
