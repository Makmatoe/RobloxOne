<Window x:Class="SessionDock.UpdateConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SessionDock update" Width="640" Height="650"
        MinWidth="440" MinHeight="420"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text"
        UseLayoutRounding="True" ShowInTaskbar="False">
    <Border Style="{StaticResource DialogShell}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="UpdateTitleText"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="24" FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Review the signed release details before installing."
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="13" Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Row="1" Margin="0,18,0,0" Padding="16,13"
                    Background="{DynamicResource InsetSurfaceBrush}"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="SIGNED RELEASE VERIFIED"
                                   Foreground="{DynamicResource SuccessTextBrush}"
                                   FontSize="11"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="PublishedText"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="12"
                                   Margin="0,5,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="SizeText" Grid.Column="1"
                               Foreground="{DynamicResource MutedBrush}"
                               FontSize="12" Margin="18,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" Text="RELEASE NOTES"
                       Foreground="{DynamicResource SubtleBrush}" FontSize="11"
                       FontWeight="Bold" Margin="0,18,0,8"/>

            <Border Grid.Row="3" MinHeight="120" Padding="14"
                    Background="{DynamicResource InsetSurfaceBrush}"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1">
                <TextBox x:Name="ReleaseNotesBox"
                         IsReadOnly="True" IsReadOnlyCaretVisible="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent" BorderThickness="0"
                         Padding="2" Foreground="{DynamicResource TextBrush}"
                         FontSize="13" TextBlock.LineHeight="20"
                         AutomationProperties.Name="Signed release notes"/>
            </Border>

            <TextBlock x:Name="IntegrityText" Grid.Row="4"
                       Foreground="{DynamicResource MutedBrush}" FontSize="11"
                       Margin="0,14,0,0" TextWrapping="Wrap"/>

            <Grid Grid.Row="5" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="App files are replaced; local account data stays outside the install folder."
                           Foreground="{DynamicResource MutedBrush}" FontSize="11"
                           VerticalAlignment="Center" TextWrapping="Wrap"
                           Margin="0,0,18,0"/>
                <Button Grid.Column="1" Content="Cancel"
                        Click="CancelButton_Click" IsCancel="True"
                        Background="{DynamicResource ControlSurfaceBrush}"
                        Foreground="{DynamicResource ControlTextBrush}"
                        Padding="16,9"
                        Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="Install update"
                        Click="InstallButton_Click" IsDefault="True"
                        Padding="22,9"
                        AutomationProperties.Name="Install integrity-checked update"/>
            </Grid>
        </Grid>
    </Border>
</Window>
