<Window x:Class="SessionDock.AccountAppearanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit account" Width="520" SizeToContent="Height"
        MinWidth="400" MinHeight="340"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text"
        UseLayoutRounding="True" ShowInTaskbar="False">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Border Margin="16" Padding="22" CornerRadius="18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="#293042" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Account appearance" Foreground="White"
                           FontSize="22" FontWeight="SemiBold"/>
                <TextBlock x:Name="AccountIdentityText" Grid.Row="1"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12" Margin="0,5,0,0"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <TextBlock Text="Custom label" Foreground="#C8D0DE"
                               FontSize="12" FontWeight="SemiBold"/>
                    <Border Height="48" Margin="0,7,0,0"
                            Style="{StaticResource TextFieldShell}">
                        <TextBox x:Name="LabelBox" MaxLength="40"
                                 Style="{StaticResource EmbeddedTextBox}"
                                 AutomationProperties.Name="Account label"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,18,0,0">
                    <TextBlock Text="Account color" Foreground="#C8D0DE"
                               FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock Text="Choose the accent used by this account card."
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11" Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                    <WrapPanel x:Name="ColorChoices" Margin="0,10,0,0">
                        <Button Tag="#7C5CFC" Click="ColorButton_Click"
                                Width="44" Height="38" Padding="0" Margin="0,0,8,8"
                                Background="#7C5CFC" Foreground="White" FontSize="18"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                AutomationProperties.Name="Purple"/>
                        <Button Tag="#4D8DFF" Click="ColorButton_Click"
                                Width="44" Height="38" Padding="0" Margin="0,0,8,8"
                                Background="#4D8DFF" Foreground="White" FontSize="18"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                AutomationProperties.Name="Blue"/>
                        <Button Tag="#27B58A" Click="ColorButton_Click"
                                Width="44" Height="38" Padding="0" Margin="0,0,8,8"
                                Background="#27B58A" Foreground="White" FontSize="18"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                AutomationProperties.Name="Green"/>
                        <Button Tag="#E0A33A" Click="ColorButton_Click"
                                Width="44" Height="38" Padding="0" Margin="0,0,8,8"
                                Background="#E0A33A" Foreground="White" FontSize="18"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                AutomationProperties.Name="Gold"/>
                        <Button Tag="#E36B8D" Click="ColorButton_Click"
                                Width="44" Height="38" Padding="0" Margin="0,0,8,8"
                                Background="#E36B8D" Foreground="White" FontSize="18"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                AutomationProperties.Name="Rose"/>
                        <Button Tag="#A56DE2" Click="ColorButton_Click"
                                Width="44" Height="38" Padding="0" Margin="0,0,8,8"
                                Background="#A56DE2" Foreground="White" FontSize="18"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                AutomationProperties.Name="Violet"/>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Border x:Name="SelectedColorPreview" Width="30" Height="30"
                                CornerRadius="9" BorderBrush="White" BorderThickness="2"/>
                        <TextBlock x:Name="SelectedColorText" Foreground="#C8D0DE"
                                   FontSize="12" Margin="10,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <WrapPanel Grid.Row="4" HorizontalAlignment="Right"
                           Margin="0,20,0,0">
                    <Button Content="Cancel" Click="CancelButton_Click" IsCancel="True"
                            Background="#252C3B" Padding="18,9" Margin="0,0,10,0"/>
                    <Button Content="Save changes" Click="SaveButton_Click" IsDefault="True"
                            Padding="22,9"
                            AutomationProperties.Name="Save account appearance"/>
                </WrapPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</Window>
