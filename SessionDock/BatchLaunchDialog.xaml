<Window x:Class="SessionDock.BatchLaunchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch launch" Width="560" SizeToContent="Height"
        MinWidth="420" MinHeight="400"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text"
        UseLayoutRounding="True" ShowInTaskbar="False">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Border Margin="16" Padding="22" CornerRadius="18"
            Background="{StaticResource PanelBrush}"
            BorderBrush="#293042" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Batch launch" Foreground="White"
                           FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="Each account uses its own saved destination. A blank account uses the first selected account's destination."
                           Foreground="{StaticResource MutedBrush}" FontSize="13"
                           Margin="0,6,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="Starting the batch closes every currently running verified Roblox Player instance."
                           Foreground="#E0A33A" FontSize="12" FontWeight="SemiBold"
                           Margin="0,9,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="SessionDock verifies every selected sign-in first, so an unavailable account cannot close your clients before the batch starts."
                           Foreground="#8E99AD" FontSize="11"
                           Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,22,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ACCOUNTS" Foreground="#7F8BA0" FontSize="11"
                           FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="All" Click="SelectAllButton_Click"
                            Background="Transparent" Foreground="#9A89FF"
                            Padding="8,4" FontSize="12"/>
                    <Button Content="None" Click="SelectNoneButton_Click"
                            Background="Transparent" Foreground="#7F8BA0"
                            Padding="8,4" FontSize="12"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Height="210" Background="#0D1017" CornerRadius="12"
                    BorderBrush="#242B3A" BorderThickness="1" Padding="8">
                <ListBox x:Name="AccountsList" Background="Transparent"
                         BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,5"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{StaticResource KeyboardFocusVisual}"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Padding="10" Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="8" Height="46" CornerRadius="4"
                                            Background="{Binding ColorHex}"
                                            VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Identity}" Foreground="#7F8BA0"
                                                   FontSize="11" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding DestinationSummary}"
                                                   ToolTip="{Binding DestinationToolTip}"
                                                   Foreground="#9A89FF" FontSize="11"
                                                   Margin="0,3,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Grid Grid.Row="3" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="190"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Delay between launches" Foreground="#C8D0DE"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock Text="Waits after hooks finish, before switching accounts."
                               Foreground="{StaticResource MutedBrush}" FontSize="11"
                               Margin="0,4,12,0" TextWrapping="Wrap"/>
                </StackPanel>
                <ComboBox x:Name="DelayComboBox" Grid.Column="1" SelectedIndex="2"
                          Height="40" VerticalContentAlignment="Center"
                          AutomationProperties.Name="Delay between batch launches">
                    <ComboBoxItem Content="3 seconds" Tag="3"/>
                    <ComboBoxItem Content="5 seconds" Tag="5"/>
                    <ComboBoxItem Content="8 seconds (recommended)" Tag="8"/>
                    <ComboBoxItem Content="10 seconds" Tag="10"/>
                    <ComboBoxItem Content="15 seconds" Tag="15"/>
                    <ComboBoxItem Content="20 seconds" Tag="20"/>
                    <ComboBoxItem Content="30 seconds" Tag="30"/>
                </ComboBox>
            </Grid>

            <Grid Grid.Row="4" Margin="0,18,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="ValidationText" Foreground="#FF7188" FontSize="12"
                           TextWrapping="Wrap" MinHeight="18"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Cancel" Click="CancelButton_Click" IsCancel="True"
                            Background="#252C3B" Padding="18,9" Margin="0,0,10,0"/>
                    <Button Content="Start batch" Click="StartButton_Click" IsDefault="True"
                            Padding="22,9" AutomationProperties.Name="Start batch launch"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
    </ScrollViewer>
</Window>
