    <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="RaisedPanelBrush" Color="#F7F9FC"/>
    <SolidColorBrush x:Key="StrokeBrush" Color="#CBD3DE"/>
    <SolidColorBrush x:Key="TextBrush" Color="#17202B"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#526071"/>
    <SolidColorBrush x:Key="SubtleBrush" Color="#627084"/>
