<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- High Contrast deliberately uses only operating-system colors. -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="PanelBrush" Color="{x:Static SystemColors.WindowColor}"/>
    <SolidColorBrush x:Key="RaisedPanelBrush" Color="{x:Static SystemColors.ControlColor}"/>
