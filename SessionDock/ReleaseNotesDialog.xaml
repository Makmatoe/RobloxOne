<Window x:Class="SessionDock.ReleaseNotesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SessionDock release notes" Width="680" Height="640"
        MinWidth="460" MinHeight="400"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable Text"
        UseLayoutRounding="True" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="ReleaseTabButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="15,11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource DialogShell}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Release notes"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="Changes included with this copy of SessionDock."
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="12" Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,18,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="CurrentReleaseButton"
                        Style="{StaticResource ReleaseTabButton}"
                        Background="{DynamicResource AccentSurfaceBrush}"
                        Foreground="{DynamicResource TextBrush}"
                        Margin="0,0,5,0"
                        Click="CurrentReleaseButton_Click"
                        PreviewKeyDown="ReleaseTabButton_PreviewKeyDown">
                    <StackPanel>
                        <TextBlock Text="CURRENT" FontSize="9"
                                   Foreground="{DynamicResource InfoTextBrush}"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="CurrentVersionText"
                                   FontSize="13" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <Button x:Name="PreviousReleaseButton" Grid.Column="1"
                        Style="{StaticResource ReleaseTabButton}"
                        Background="{DynamicResource ControlSurfaceBrush}"
                        Foreground="{DynamicResource ControlTextBrush}"
                        Margin="5,0,0,0"
                        Click="PreviousReleaseButton_Click"
                        PreviewKeyDown="ReleaseTabButton_PreviewKeyDown">
                    <StackPanel>
                        <TextBlock Text="PREVIOUS" FontSize="9"
                                   Foreground="{DynamicResource SubtleBrush}"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="PreviousVersionText"
                                   FontSize="13" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid Grid.Row="2">
                <Border x:Name="CurrentNotesPanel" Padding="14"
                        Background="{DynamicResource InsetSurfaceBrush}"
                        CornerRadius="9"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1">
                    <TextBox x:Name="CurrentNotesBox"
                             IsReadOnly="True" IsReadOnlyCaretVisible="True"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent" BorderThickness="0"
                             Padding="2" Foreground="{DynamicResource TextBrush}"
                             FontSize="13" TextBlock.LineHeight="20"/>
                </Border>
                <Border x:Name="PreviousNotesPanel" Padding="14"
                        Visibility="Collapsed"
                        Background="{DynamicResource InsetSurfaceBrush}"
                        CornerRadius="9"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1">
                    <TextBox x:Name="PreviousNotesBox"
                             IsReadOnly="True" IsReadOnlyCaretVisible="True"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent" BorderThickness="0"
                             Padding="2" Foreground="{DynamicResource TextBrush}"
                             FontSize="13" TextBlock.LineHeight="20"/>
                </Border>
            </Grid>

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Bundled with this app — no network connection is used."
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="11" VerticalAlignment="Center"
                           TextWrapping="Wrap" Margin="0,0,16,0"/>
                <Button x:Name="DoneButton" Grid.Column="1"
                        Content="Done" IsCancel="True"
                        Background="{DynamicResource ControlSurfaceBrush}"
                        Foreground="{DynamicResource ControlTextBrush}"
                        Padding="17,9"
                        AutomationProperties.Name="Close release notes"/>
            </Grid>
        </Grid>
    </Border>
</Window>
